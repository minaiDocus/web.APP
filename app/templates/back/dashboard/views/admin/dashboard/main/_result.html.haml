%table.table.table-condensed.table-striped{ data: { total: collection.count.to_i }}
  %thead
    %tr
      %th.text-center= header[1]
      %th.text-center= header[2]
      %th.text-center= header[3]
      %th.text-center= header[4]
  %tbody
    - total = 0
    - if header[5].present?
      - if collection.count > 0
        - collection.each do |object|
          - organization = Organization.find(object[0][0])
          - date = object[0][2]
          - iban = object[0][1]
          - count = object[1]
          %tr
            %td.text-center
              - if date
                = l(date, format: '%d %b %Y %H:%M')
              - else
                \-
            %td.text-center= organization.name
            %td.text-center= count
            %td.text-center= iban
        %tr
          %td.semibold Total
          %td
          %td.text-center
            %strong= collection.sum {|h| h[1]}
          %td
      - else
        %tr
          %td.text-center{ colspan: 4 }
            %i Aucun
    - else
      - if collection.count > 0
        - collection.each do |object|
          - total = total + object.document_count
          %tr
            %td.text-center
              - if object.date
                - if object.date.today?
                  = l(object.date, format: '%H:%M')
                - else
                  = l(object.date, format: '%d %b %Y %H:%M')
              - else
                \-
            %td.text-center= object.name
            %td.text-center= object.document_count
            %td.text-center{ title: object.try(:error_message).presence || '-' }
              = object.message == false ? '-' : sanitize(object.message, :tags => %w(br))
        %tr
          %td.text-center.semibold Total
          %td
          %td.text-center.semibold= total
          %td
      - else
        %tr
          %td.text-center{ colspan: 4 }
            %i Aucun
