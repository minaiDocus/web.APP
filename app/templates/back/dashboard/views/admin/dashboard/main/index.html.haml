= stylesheet_link_tag 'back/dashboard/assets/stylesheets/main'

#dashboard.derivationRight
  %h3.semibold Flux de traitement
  %hr
  .mb-4
  .row
    .col-md-2
      .box.heightGroups.groups_1.ocr_needed_temp_packs
        .head-box.p-3.pt-2
          .badge-content.back-grey.for-badge= glyphicon('magnifying-glass', size: 18, color: "white")
          .text-end
            %h5.bold.no-margin.no-padding OCR
            %label.count.ocr_needed_temp_packs
              %img{ src: '/assets/application/spinner_gray_alpha.gif', alt: 'spin gif'}
        .mb-1
        %hr.no-margin.no-padding
        .foot-box.p-2
          .text-end.label_more_info
            %label.semibold Voir détails >>
            .hide.more-info
              .content#ocr_needed_temp_packs
    .col-md-3
      .box.heightGroups.groups_1.bundle_needed_temp_packs
        .head-box.p-3.pt-2
          .badge-content.back-magenta.for-badge= glyphicon('justify-center', size: 18, color: "white")
          .text-end
            %h5.bold.no-margin.no-padding Regroupement en cours
            %label.count.bundle_needed_temp_packs
              %img{ src: '/assets/application/spinner_gray_alpha.gif', alt: 'spin gif'}
        .mb-1
        %hr.no-margin.no-padding
        .foot-box.p-2
          .text-end.label_more_info
            %label.semibold Voir détails >>
            .hide.more-info
              .content#bundle_needed_temp_packs
    .col-md-3
      .box.heightGroups.groups_1.processing_temp_packs
        .head-box.p-3.pt-2
          .badge-content.back-yellow.for-badge= glyphicon('transfer', size: 18, color: "white")
          .text-end
            %h5.bold.no-margin.no-padding Conversion en pièces
            %label.count.processing_temp_packs
              %img{ src: '/assets/application/spinner_gray_alpha.gif', alt: 'spin gif'}
        .mb-1
        %hr.no-margin.no-padding
        .foot-box.p-2
          .text-end.label_more_info
            %label.semibold Voir détails >>
            .hide.more-info
              .content#processing_temp_packs
    .col-md-2
      .box.heightGroups.groups_1.awaiting_supplier_recognition
        .head-box.p-3.pt-2
          .badge-content.back-blue-sky.for-badge= glyphicon('list-rich', size: 18, color: "white")
          .text-end
            %h5.bold.no-margin.no-padding Recon. Fou.
            %label.count.awaiting_supplier_recognition
              %img{ src: '/assets/application/spinner_gray_alpha.gif', alt: 'spin gif'}              
        .mb-1
        %hr.no-margin.no-padding
        .foot-box.p-2
          .text-end.label_more_info
            %label.semibold Voir détails >>
            .hide.more-info
              .content#awaiting_supplier_recognition
    .col-md-2
      .box.heightGroups.groups_1.cedricom_orphans
        .head-box.p-3.pt-2
          .badge-content.back-blue.for-badge= glyphicon('script', size: 18, color: "white")
          .text-end
            %h5.bold.no-margin.no-padding Cédricom
            %label.count.cedricom_orphans
              %img{ src: '/assets/application/spinner_gray_alpha.gif', alt: 'spin gif'}
        .mb-1
        %hr.no-margin.no-padding
        .foot-box.p-2
          .text-end.label_more_info
            %label.semibold Voir détails >>
            .hide.more-info
              .content#cedricom_orphans
  .mb-4
  .row
    .col-md-4
      .box.awaiting_pre_assignments.blocked_pre_assignments
        .head-box.p-3.pt-2
          .badge-content.back-green.for-badge= glyphicon('random', size: 18, color: "white")
          .text-end
            %h5.bold.no-margin.no-padding Pré-afféctation
            %label En cours :
            %label.count.blocked_pre_assignments
              %img{ src: '/assets/application/spinner_gray_alpha.gif', alt: 'spin gif'}
            %br
            %label En attente :
            %label.count.awaiting_pre_assignments
              %img{ src: '/assets/application/spinner_gray_alpha.gif', alt: 'spin gif'}
        .mb-1
        %hr.no-margin.no-padding
        .foot-box.p-2
          .text-end.label_more_info
            %label.semibold Voir détails >>
            .hide.more-info
              .content#blocked_pre_assignments
              %hr
              .content#awaiting_pre_assignments

    .col-md-4
      .box.reports_delivery.failed_reports_delivery
        .head-box.p-3.pt-2
          .badge-content.back-blue-sky.for-badge= glyphicon('share', size: 18, color: "white")
          .text-end
            %h5.bold.no-margin.no-padding Livraison Pré-afféctation
            %label En cours :
            %label.count.reports_delivery
              %img{ src: '/assets/application/spinner_gray_alpha.gif', alt: 'spin gif'}
            %br
            %label En attente :
            %label.count.failed_reports_delivery
              %img{ src: '/assets/application/spinner_gray_alpha.gif', alt: 'spin gif'}

        .mb-1
        %hr.no-margin.no-padding
        .foot-box.p-2
          .text-end.label_more_info
            %label.semibold Voir détails >>
            .hide.more-info
              .content#reports_delivery
              %hr
              .content#failed_reports_delivery
    .col-md-4
      .box.failed_packs_delivery.currently_being_delivered_packs
        .head-box.p-3.pt-2
          .badge-content.back-grey.for-badge= glyphicon('project', size: 18, color: "white")
          .text-end
            %h5.bold.no-margin.no-padding Livraison GED client
            %label En cours :
            %label.count.currently_being_delivered_packs
              %img{ src: '/assets/application/spinner_gray_alpha.gif', alt: 'spin gif'}
            %br
            %label En attente :
            %label.count.failed_packs_delivery
              %img{ src: '/assets/application/spinner_gray_alpha.gif', alt: 'spin gif'}

        .mb-1
        %hr.no-margin.no-padding
        .foot-box.p-2
          .text-end.label_more_info
            %label.semibold Voir détails >>
            .hide.more-info
              .content#currently_being_delivered_packs
              %hr
              .content#failed_packs_delivery
  
  .mb-5
  %h3.semibold
    Information dépuis
    %strong= I18n.l(30.days.ago)
    jusqu'à Aujourd'hui
  %hr

  .row
    .col-md-6
      .box.p-3
        .text-center.mb-2
          %label.semibold Traitement des documents
        #chart_flux_document
          %img{ src: '/assets/application/spinner_gray_alpha.gif', alt: 'spin gif'}
    .col-md-6
      .box.p-3
        .text-center.mb-2
          %label.semibold Livraison des documents
        #document_delivery
          %img{ src: '/assets/application/spinner_gray_alpha.gif', alt: 'spin gif'}
  .row
    .col-md-12
      .box.p-3
        .text-center.mb-2
          %label.semibold Documents téléversés par api        
        #document_api
          %img{ src: '/assets/application/spinner_gray_alpha.gif', alt: 'spin gif'}
  .row
    .col-md-6
      .box.p-3
        .text-center.mb-2
          %label.semibold Opérations bancaires
        #bank_operation
          %img{ src: '/assets/application/spinner_gray_alpha.gif', alt: 'spin gif'}
    .col-md-6
      .box.p-3
        .text-center.mb-2
          %label.semibold Répartition des organisations et clients par logiciel comptable
        #software_customers
          %img{ src: '/assets/application/spinner_gray_alpha.gif', alt: 'spin gif'}

.modal#see-more-info
  .modal-dialog{style: 'min-width: 800px'}
    .modal-content
      .modal-header
        %h5.modal-title.bold Détail
        %button.btn-close{'aria-label' => 'Close', 'data-bs-dismiss' => 'modal', :type => 'button'}
      .modal-body
        
      .modal-footer
 

