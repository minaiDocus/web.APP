- months = ["Janvier","Février","Mars","Avril","Mai","Juin","Juillet","Août","Septembre","Octobre","Novembre","Décembre"]

.container-fluid
  %h1 TEST: Infos sur l'utilsateur
  %h3
    %span Utilisateur :
    %span= current_user.name
  %h3
    %span Nombre de billings :
    %b= current_user.billings.count
  .mb-4
  %h2 
    %span Détails
    %span= current_user.billings.first.name
  %h3
    %span Title :
    %span= current_user.billings.first.title
  %h3
    %span Période :
    %span= current_user.billings.first.period
  .mb-4
  .row
    .col-md-12
      .row
        .col-md-1.text-center.p-1
          %span.badge.bg-info.semibold Légende :
        .col-md-2.p-2 : Aucun documents reçus
        .col-md-2.p-2 : Documents papier reçus
        .col-md-2.p-2 : Documents téléversés reçus
        .col-md-2.p-2 : Documents papier reçus et documents téléversés reçus
        .col-md-2.p-2
          %button.btn.btn-primary.semibold.w-100
            %span.me-4= glyphicon('share-boxed', { size: '15', color: 'white'})
            %span.text-white Export xls

  .mb-4
