%button.btn.btn-primary{"type"=>"button", "data-bs-toggle"=>"modal", "data-bs-target"=>"#exampleModal"}
  %span Ouvrir fenêtre modal

.modal#exampleModal.fade.in{"tabindex"=>"-1", "aria-labelledby"=>"exampleModalLabel", "aria-hidden"=>"true"}
