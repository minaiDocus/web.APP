.modal#invoiceModal.fade.in{"tabindex"=>"-1", "aria-labelledby"=>"invoiceModalLabel", "aria-hidden"=>"true"}
  .modal-dialog.modal-dialog-scrollable.modal-dialog-centered.modal-xl
    .modal-content
      .modal-header
        .user
          %h4.modal-title.bold IDOC%001 - iDocus
        .period.no-border.ms-5.no-padding
          %h3.no-margin.grey-label.regular Month YEAR
        %button.btn-close{"type"=>"button", "data-bs-dismiss"=>"modal", "aria-label"=>"Close"}
      .modal-body.clearfix.back-grey
        .documentlist
          .box
            %table.table.table-striped
              %thead
                %tr
                  %th Nom des documents
                  %th.center Pièces
                  %th.center Pré-aff.
                  %th.center Feuilles
                  %th.center Pages
                  %th.center Attaches
                  %th.center Hors format
                  %th.last
              %tbody
                %tr
                  %td.semibold Total
                  %td.center
                    %b 0(0, 0, 0, 0)
                  %td.center
                    %b 0
                  %td.center
                    %b 0
                  %td.center
                    %b 0(0, 0, 0, 0)
                  %td.center
                    %b 0
                  %td.center
                    %b 0
                  %td.last
        .optionlist.box
          %table.table.table-striped
            %thead
              %tr
                %th.header Paramètre
                %th.header Valeur
                %th.header Prix HT
            %tbody
              %tr
                %td.semibold iDo'Classique
                %td Téléchargement + Pré-saisie comptable
                %td 11,00 €
              %tr
                %td.semibold Courrier
                %td Envoi par courrier A/R
                %td 11,00 €
              %tr
                %td.semibold Automates
                %td Récupération banque
                %td 5,00 €
              %tr
                %td
                %td.semibold
                  %b Total :
                %td.semibold.text-end 41,00 €
              %tr
                %td
                %td.semibold
                  %b Facture(s) :
                %td
      .modal-footer
        .row.w-100.form-group
          .col-md-8.p-2
            %label Légende : Total (Téléversées, Numérisées, iDocus'Box, Automatique)
          .col-md-4.text-end
            %a.left.btn.btn-light
              = glyphicon('chevron-left', size: '13')
            %a.up.btn.btn-light
              = glyphicon('chevron-top', size: '13')
            %a.down.btn.btn-light
              = glyphicon('chevron-bottom', size: '13')
            %a.right.btn.btn-light
              = glyphicon('chevron-right', size: '13')

%script{ :type => "text/x-tmpl", :id => "tmpl-period" }
