- months = ["Janvier","Février","Mars","Avril","Mai","Juin","Juillet","Août","Septembre","Octobre","Novembre","Décembre"]

.container-fluid
  .mb-4
  .row
    .col-md-12
      .row
        .col-md-1.text-center.p-1
          %span.badge.bg-info.semibold Légende :
        .col-md-2.p-2 : Aucun documents reçus
        .col-md-2.p-2 : Documents papier reçus
        .col-md-2.p-2 : Documents téléversés reçus
        .col-md-2.p-2 : Documents papier reçus et documents téléversés reçus
        .col-md-2.p-2
          %a.btn.btn-success.semibold.w-100{"href"  =>  "#"} Export xls

  .mb-4
  .row
    .col-md-12.d-inline
      .form-group
        %label{"for" => "value_filter"} Affichage par :
