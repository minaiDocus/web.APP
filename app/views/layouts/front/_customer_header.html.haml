.heading_customer.mb-5
  .customer_header
    %input#organization_id{type: :hidden, value: @organization.id, name: 'organization_id'}
    %input#customer_id{type: :hidden, value: @customer.id, name: 'customer_id'}
    .row.derivationRight
      .col-md-12
        - options = { size: '15', color: 'rgba(26, 26, 26, 0.7);'}
        .row.clearfix
          .col-md-6.text-start.p-2    
            %h3.bold.text-start
              %span.me-1 Clients :
              %span.badge.bg-dark.regular= @customer.info
              - if @customer.inactive?
                %span.badge.badge-danger.text-start.ms-2.regular.closed_account Dossier clôturé
          .col-md-6.text-end.no-padding
            - if @customer.active?
              = link_to glyphicon('ban', { size: '15', color: '#FF4848'}) + ' Clôturer le dossier', account_close_confirm_organization_customer_path(@organization, @customer), class: 'btn btn-danger semibold close_customer'
            - else

              = link_to 'Réouvrir le dossier', reopen_account_organization_customer_path(@organization, @customer), class: 'btn btn-primary semibold', data: { toggle: "confirmation", title: "Voulez-vous réellement réouvrir le dossier #{@customer.info} ?" }, method: :put

    .mb-4

    - if @customer.still_active?
      .w-100
        %span.auto-scroll-span-left.hide.ml-1.mr-1.float-start
          %button.btn.btn-default
            = glyphicon('arrow-left', size: '16', color: '#C1D837' )
        %span.auto-scroll-span-right.hide.mr-auto.ml-1.float-end
          %button.btn.btn-default
            = glyphicon('arrow-right', size: '16', color: '#C1D837')
        .main-menu-content.auto-scroll-div
          %ul.list.nav.nav-tabs.ms-3.derivationLeft
            %li.nav-item.no-margin
              %a.semibold.nav-link#customer_information{ class: ('active' if (controller_path == 'customers/main' && action_name == 'show') ), href: organization_customer_path(@organization, @customer) } Informations générales
            - if @customer.active? && !@organization.specific_mission
              %li.nav-item.no-margin
                %a.semibold.nav-link#customer_subscription{ class: ('active' if (controller_path == 'subscriptions/main' && action_name == 'edit')), href: edit_organization_customer_subscription_path(@organization, @customer) } Forfait
              %li.nav-item.no-margin
                %a.semibold.nav-link#orders-tab{ class: ('active' if (controller_path == 'orders/main' && action_name == 'index')), href: organization_customer_orders_path(@organization, @customer) } Commandes Kits/Scan
              %li.nav-item.no-margin
                %a.semibold.nav-link#adresses-tab{ class: ('active' if params[:tab] == 'addresses'), href: '#' } Adresses
            - if @organization.specific_mission
              %li.nav-item.no-margin
                %a.semibold.nav-link#journals-tab{ class: ('active' if params[:tab] == 'journals'), href: '#' } Dossiers
            - else
              %li.nav-item.no-margin
                %a.semibold.nav-link#journals-tab{ class: ('active' if params[:tab] == 'journals'), href: '#' } Journaux comptables
              %li.nav-item.no-margin
                %a.semibold.nav-link#compta-tab{ class: ('active' if params[:tab] == 'compta'), href: '#' } Paramètres
              - if @customer.uses?(:ibiza)
                %li.nav-item.no-margin
                  %a.semibold.nav-link#ibizabox_tab{ class: ('active' if params[:tab] == 'ibiza_box'), href: '#' } iBiza Box
              %li.nav-item.dropdown.no-margin
                %a.semibold.nav-link.dropdown-toggle#softwares-list{ "data-bs-toggle" => "dropdown", "aria-expanded" => "false", href: '#' } Logiciels comptables / export csv
                %ul.dropdown-menu{ "aria-labelledby" => "softwares-list" }
                  - if software_uses('ibiza')   
                    %li.clearfix
                      %a.semibold.nav-link.dropdown-item#ibiza-tab{ href: '#' } 
                        %span.float-start iBiza
                        - if @customer.uses?(:ibiza)
                          = glyphicon('check', { size: '15', color: 'rgba(26, 26, 26, 0.7);', class: 'float-end' })
                  - if software_uses('exact_online')
                    %li.clearfix
                      %a.semibold.nav-link.dropdown-item#exact-online-tab{ href: '#' } 
                        %span.float-start Exact Online
                        - if @customer.uses?(:exact_online)
                          = glyphicon('check', { size: '15', color: 'rgba(26, 26, 26, 0.7);', class: 'float-end' })
                  - if software_uses('my_unisoft')
                    %li.clearfix
                      %a.semibold.nav-link.dropdown-item#my-unisoft-tab{ href: '#' } 
                        %span.float-start My Unisoft
                        - if @customer.uses?(:my_unisoft)
                          = glyphicon('check', { size: '15', color: 'rgba(26, 26, 26, 0.7);', class: 'float-end' })
                  - if @organization.try(:coala).try(:used?)  
                    %li.clearfix
                      %a.semibold.nav-link.dropdown-item#coala-tab{ href: '#' } 
                        %span.float-start Coala
                        - if @customer.uses?(:coala)
                          = glyphicon('check', { size: '15', color: 'rgba(26, 26, 26, 0.7);', class: 'float-end' })
                  - if @organization.try(:quadratus).try(:used)
                    %li.clearfix
                      %a.semibold.nav-link.dropdown-item#quadratus-tab{ href: '#' } 
                        %span.float-start Quadratus
                        - if @customer.uses?(:quadratus)
                          = glyphicon('check', { size: '15', color: 'rgba(26, 26, 26, 0.7);', class: 'float-end' })
                  - if @organization.try(:cegid).try(:used?)
                    %li.clearfix
                      %a.semibold.nav-link.dropdown-item#cegid-tab{ href: '#' } 
                        %span.float-start Cegid
                        - if @customer.uses?(:cegid)
                          = glyphicon('check', { size: '15', color: 'rgba(26, 26, 26, 0.7);', class: 'float-end' })
                  - if @organization.try(:fec_agiris).try(:used?)
                    %li.clearfix
                      %a.semibold.nav-link.dropdown-item#fec-agiris-tab{ href: '#' } 
                        %span.float-start Fec Agiris
                        - if @customer.uses?(:fec_agiris)
                          = glyphicon('check', { size: '15', color: 'rgba(26, 26, 26, 0.7);', class: 'float-end' })
                  - if @organization.try(:fec_acd).try(:used?)
                    %li.clearfix
                      %a.semibold.nav-link.dropdown-item#fec-acd-tab{ href: '#' } 
                        %span.float-start Fec ACD
                        - if @customer.uses?(:fec_acd)
                          = glyphicon('check', { size: '15', color: 'rgba(26, 26, 26, 0.7);', class: 'float-end' })
                  - if @organization.try(:csv_descriptor).try(:used?)
                    %li.clearfix
                      %a.semibold.nav-link.dropdown-item#csv-descriptor-tab{ href: '#' } 
                        %span.float-start Format d’export (.csv)
                        - if @customer.uses?(:csv_descriptor)
                          = glyphicon('check', { size: '15', color: 'rgba(26, 26, 26, 0.7);', class: 'float-end' })   
              %li.nav-item.no-margin
                %a.semibold.nav-link#accounting-plan-tab{ class: ('active' if params[:tab] == 'accounting_plan'), href: '#' } Plan comptable
              - if @organization.mcf_settings.try(:access_token).present? || @customer.try(:mcf_documents).try(:not_processable).try(:any?)
                %li.nav-item.no-margin{ "role" => "presentation" }
                  %a.semibold.nav-link#mcf-tab{ class: ('active' if params[:tab] == 'mcf'), href: '#' } My Company Files
              - if @organization.knowings.try(:ready?)
                %li.nav-item.no-margin
                  %a.semibold.nav-link#ged-tab{ class: ('active' if params[:tab] == 'ged'), href: '#' } Outil GED
              - if @user.is_admin && @customer.active? && !@organization.specific_mission
                %li.nav-item.no-margin
                  %a.semibold.nav-link#file-storages-tab{ class: ('active' if params[:tab] == 'file_storage'), href: '#' } Stockages externes


  .customer_content
    != content_for?(:content) ? yield(:content) : yield